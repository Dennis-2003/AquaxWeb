@model IEnumerable<AquaxWeb.Models.Pedido>
@{
    ViewData["Title"] = "Logística y Despacho";
    var repartidores = ViewBag.Repartidores as IEnumerable<AquaxWeb.Models.Usuario>;
    
    var pendientes = Model.Where(p => p.Estado == "Pendiente");
    var enCamino = Model.Where(p => p.Estado == "EnCamino");
    var entregados = Model.Where(p => p.Estado == "Entregado");
}

<div class="mb-8 flex items-center justify-between">
    <div>
        <h1 class="text-3xl font-headline-md font-bold text-on-surface">Panel de Despacho (Kanban)</h1>
        <p class="text-on-surface-variant font-body-md mt-1">Asigna rutas, controla entregas y gestiona los envases retornables.</p>
    </div>
</div>

@if (TempData["Mensaje"] != null)
{
    <div class="bg-surface-container-lowest border-l-4 border-secondary p-4 mb-6 rounded-lg shadow-sm flex items-center gap-3">
        <span class="material-symbols-outlined text-secondary">info</span>
        <p class="text-primary font-body-md">@TempData["Mensaje"]</p>
    </div>
}

<div class="grid grid-cols-1 md:grid-cols-@(ViewBag.EsAdmin ? "3" : "2") gap-6">
    
    @if (ViewBag.EsAdmin)
    {
        <!-- Columna: Pendientes -->
    <div class="bg-surface-container/30 backdrop-blur-md border border-outline-variant/30 rounded-2xl p-4 shadow-sm h-[calc(100vh-200px)] overflow-y-auto">
        <div class="flex items-center justify-between mb-4 sticky top-0 bg-surface-container/90 p-2 rounded-lg backdrop-blur-xl z-10">
            <h2 class="font-headline-sm font-semibold text-on-surface flex items-center gap-2">
                <span class="material-symbols-outlined text-error">pending_actions</span>
                Pendientes
            </h2>
            <span class="bg-error/10 text-error px-2 py-1 rounded-full text-sm font-bold">@pendientes.Count()</span>
        </div>

        <div class="space-y-4">
            @foreach (var p in pendientes)
            {
                <div class="bg-surface-container-lowest p-4 rounded-xl shadow-sm border border-outline-variant/50 hover:shadow-md transition-shadow">
                    <div class="flex justify-between items-start mb-2">
                        <span class="text-xs font-bold bg-surface-container-high px-2 py-1 rounded-md text-on-surface">#@p.CodigoRastreo</span>
                        <span class="text-xs text-on-surface-variant">@p.FechaPedido.ToString("HH:mm")</span>
                    </div>
                    <h3 class="font-bold text-primary truncate">@p.Cliente.Nombre</h3>
                    <p class="text-sm text-on-surface-variant truncate mb-4"><span class="material-symbols-outlined text-[16px] align-middle">location_on</span> @p.Cliente.Direccion</p>
                    
                    <form asp-action="AsignarRepartidor" method="post" class="flex flex-col gap-2">
                        <input type="hidden" name="pedidoId" value="@p.Id" />
                        <select name="usuarioId" class="text-sm rounded-lg border-outline-variant bg-surface text-on-surface w-full focus:ring-secondary focus:border-secondary" required>
                            <option value="">Seleccionar Repartidor...</option>
                            @if (repartidores != null)
                            {
                                foreach (var rep in repartidores)
                                {
                                    <option value="@rep.Id">@rep.Nombre</option>
                                }
                            }
                        </select>
                        <button type="submit" class="w-full bg-primary hover:bg-primary/90 text-on-primary py-2 rounded-lg text-sm font-semibold transition-colors flex items-center justify-center gap-2">
                            <span class="material-symbols-outlined text-[18px]">local_shipping</span>
                            Despachar
                        </button>
                    </form>
                </div>
            }
            @if(!pendientes.Any())
            {
                <div class="text-center p-8 opacity-50">
                    <span class="material-symbols-outlined text-4xl mb-2">check_circle</span>
                    <p class="text-sm">No hay pedidos pendientes</p>
                </div>
            }
        </div>
    </div>
    }

    <!-- Columna: En Camino -->
    <div class="bg-surface-container/30 backdrop-blur-md border border-outline-variant/30 rounded-2xl p-4 shadow-sm h-[calc(100vh-200px)] overflow-y-auto">
        <div class="flex items-center justify-between mb-4 sticky top-0 bg-surface-container/90 p-2 rounded-lg backdrop-blur-xl z-10">
            <h2 class="font-headline-sm font-semibold text-on-surface flex items-center gap-2">
                <span class="material-symbols-outlined text-secondary animate-pulse">local_shipping</span>
                En Ruta
            </h2>
            <span class="bg-secondary/10 text-secondary px-2 py-1 rounded-full text-sm font-bold">@enCamino.Count()</span>
        </div>

        <div class="space-y-4">
            @foreach (var p in enCamino)
            {
                <div class="bg-surface-container-lowest p-4 rounded-xl shadow-sm border border-secondary/30 relative overflow-hidden">
                    <div class="absolute top-0 left-0 w-1 h-full bg-secondary"></div>
                    
                    <div class="flex justify-between items-start mb-2 ml-2">
                        <span class="text-xs font-bold text-secondary">Repartidor: @p.Usuario?.Nombre</span>
                        <span class="text-xs font-mono bg-surface-container px-1 rounded">@p.CodigoRastreo</span>
                    </div>
                    <h3 class="font-bold text-primary ml-2 truncate">@p.Cliente.Nombre</h3>
                    
                    <form asp-action="CompletarEntrega" method="post" class="mt-4 ml-2 bg-surface-container/20 p-3 rounded-lg border border-outline-variant/30">
                        <p class="text-xs font-bold text-on-surface mb-2">Confirmar Entrega y Envases</p>
                        <input type="hidden" name="pedidoId" value="@p.Id" />
                        
                        <div class="grid grid-cols-2 gap-2 mb-3">
                            <div>
                                <label class="text-[10px] text-on-surface-variant uppercase tracking-wider">Llenos dejados</label>
                                <input type="number" name="envasesEntregados" class="w-full text-sm rounded-md border-outline-variant p-1 text-center" min="0" value="1" required />
                            </div>
                            <div>
                                <label class="text-[10px] text-on-surface-variant uppercase tracking-wider">Vacíos recogidos</label>
                                <input type="number" name="envasesRecibidos" class="w-full text-sm rounded-md border-outline-variant p-1 text-center" min="0" value="1" required />
                            </div>
                        </div>
                        <input type="text" name="observacion" placeholder="Nota opcional..." class="w-full text-xs rounded-md border-outline-variant p-1 mb-3" />
                        
                        <button type="submit" class="w-full bg-secondary hover:bg-secondary/90 text-on-secondary py-1.5 rounded-md text-sm font-bold transition-colors flex items-center justify-center gap-1">
                            <span class="material-symbols-outlined text-[16px]">task_alt</span>
                            Confirmar
                        </button>
                    </form>
                </div>
            }
             @if(!enCamino.Any())
            {
                <div class="text-center p-8 opacity-50">
                    <span class="material-symbols-outlined text-4xl mb-2">pause_circle</span>
                    <p class="text-sm">Ningún repartidor en ruta</p>
                </div>
            }
        </div>
    </div>

    <!-- Columna: Entregados (Hoy) -->
    <div class="bg-surface-container/30 backdrop-blur-md border border-outline-variant/30 rounded-2xl p-4 shadow-sm h-[calc(100vh-200px)] overflow-y-auto opacity-70 hover:opacity-100 transition-opacity">
        <div class="flex items-center justify-between mb-4 sticky top-0 bg-surface-container/90 p-2 rounded-lg backdrop-blur-xl z-10">
            <h2 class="font-headline-sm font-semibold text-on-surface flex items-center gap-2">
                <span class="material-symbols-outlined text-[#1b5e20]">done_all</span>
                Completados
            </h2>
            <span class="bg-[#1b5e20]/10 text-[#1b5e20] px-2 py-1 rounded-full text-sm font-bold">@entregados.Count()</span>
        </div>

        <div class="space-y-3">
            @foreach (var p in entregados)
            {
                <div class="bg-surface-container-lowest p-3 rounded-xl border border-outline-variant/30 flex items-center justify-between">
                    <div>
                        <p class="text-sm font-bold text-primary truncate w-32" title="@p.Cliente.Nombre">@p.Cliente.Nombre</p>
                        <p class="text-xs text-on-surface-variant flex items-center gap-1 mt-1">
                            <span class="material-symbols-outlined text-[14px]">water_bottle</span>
                            Dejados: @p.EnvasesEntregados | Recogidos: @p.EnvasesRecibidos
                        </p>
                    </div>
                    <div class="text-right">
                        <span class="text-xs font-mono text-on-surface-variant">@p.FechaEntrega?.ToString("HH:mm")</span>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
