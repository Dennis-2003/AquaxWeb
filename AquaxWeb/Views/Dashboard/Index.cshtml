@model DashboardViewModel
@{
    ViewData["Title"] = "Panel de Administrador";
}

<div class="flex justify-between items-center mb-6">
    <div>
        <h2 class="text-3xl font-headline-md font-bold text-on-surface">Panel de Control (AQUAX ERP)</h2>
        <p class="text-on-surface-variant font-body-md mt-1">Bienvenido, <strong>@User.Identity?.Name</strong>. Aquí está el resumen del día.</p>
    </div>
</div>

<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4 mb-8">
    <div class="bg-surface-container-lowest rounded-2xl shadow-[0px_4px_20px_rgba(0,40,85,0.05)] p-4 text-center border border-outline-variant/30 flex flex-col justify-center">
        <span class="material-symbols-outlined text-primary mx-auto mb-2 text-[28px]">inventory_2</span>
        <p class="text-2xl font-headline-md font-bold text-primary">@Model.PedidosHoy</p>
        <p class="text-on-surface-variant text-xs uppercase tracking-wider font-bold mt-1">Pedidos Hoy</p>
    </div>
    
    <div class="bg-surface-container-lowest rounded-2xl shadow-[0px_4px_20px_rgba(0,40,85,0.05)] p-4 text-center border border-outline-variant/30 flex flex-col justify-center">
        <span class="material-symbols-outlined text-secondary mx-auto mb-2 text-[28px]">assignment_turned_in</span>
        <p class="text-2xl font-headline-md font-bold text-secondary">@Model.PedidosPendientes</p>
        <p class="text-on-surface-variant text-xs uppercase tracking-wider font-bold mt-1">Asignados</p>
    </div>
    
    <div class="bg-surface-container-lowest rounded-2xl shadow-[0px_4px_20px_rgba(0,40,85,0.05)] p-4 text-center border border-outline-variant/30 flex flex-col justify-center">
        <span class="material-symbols-outlined text-tertiary mx-auto mb-2 text-[28px]">local_shipping</span>
        <p class="text-2xl font-headline-md font-bold text-tertiary">@Model.PedidosEnRuta</p>
        <p class="text-on-surface-variant text-xs uppercase tracking-wider font-bold mt-1">En Ruta</p>
    </div>
    
    <div class="bg-surface-container-lowest rounded-2xl shadow-[0px_4px_20px_rgba(0,40,85,0.05)] p-4 text-center border-2 border-error/20 flex flex-col justify-center cursor-pointer hover:bg-error/5 transition-colors" onclick="window.location.href='/Despacho'">
        <span class="material-symbols-outlined text-error mx-auto mb-2 text-[28px]">warning</span>
        <p class="text-2xl font-headline-md font-bold text-error">@Model.PedidosSinAsignar</p>
        <p class="text-error text-xs uppercase tracking-wider font-bold mt-1">Sin Asignar</p>
    </div>
    
    <div class="bg-primary text-on-primary rounded-2xl shadow-md p-4 text-center flex flex-col justify-center relative overflow-hidden">
        <span class="material-symbols-outlined absolute right-[-10px] bottom-[-10px] text-6xl opacity-20">payments</span>
        <p class="text-2xl font-headline-md font-bold relative z-10">@Model.VentasHoy.ToString("C")</p>
        <p class="text-on-primary text-xs uppercase tracking-wider font-bold mt-1 relative z-10 opacity-90">Ventas Hoy</p>
    </div>
    
    <div class="bg-surface-container-lowest rounded-2xl shadow-[0px_4px_20px_rgba(0,40,85,0.05)] p-4 text-center border border-outline-variant/30 flex flex-col justify-center">
        <span class="material-symbols-outlined text-on-surface-variant mx-auto mb-2 text-[28px]">groups</span>
        <p class="text-2xl font-headline-md font-bold text-on-surface">@Model.TotalClientes</p>
        <p class="text-on-surface-variant text-xs uppercase tracking-wider font-bold mt-1">Clientes</p>
    </div>
</div>

<div class="flex items-center justify-between mb-4">
    <h3 class="font-headline-sm font-bold text-on-surface text-xl">Últimos Pedidos</h3>
    <a asp-controller="Pedidos" asp-action="Index" class="text-sm font-bold text-secondary flex items-center gap-1 hover:underline">
        Ver Todos <span class="material-symbols-outlined text-[16px]">arrow_forward</span>
    </a>
</div>

<div class="bg-surface-container-lowest rounded-2xl shadow-[0px_4px_20px_rgba(0,40,85,0.05)] overflow-hidden border border-outline-variant/30">
    <table class="w-full text-sm text-left">
        <thead class="bg-surface-container/50 text-on-surface-variant font-body-md uppercase tracking-wider text-xs">
            <tr>
                <th class="px-6 py-4 font-bold rounded-tl-2xl">Código</th>
                <th class="px-6 py-4 font-bold">Cliente</th>
                <th class="px-6 py-4 font-bold">Fecha</th>
                <th class="px-6 py-4 font-bold">Total</th>
                <th class="px-6 py-4 font-bold">Estado</th>
                <th class="px-6 py-4 font-bold rounded-tr-2xl">Repartidor</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-outline-variant/20">
            @foreach (var p in Model.UltimosPedidos)
            {
                <tr class="hover:bg-surface-container/30 transition-colors">
                    <td class="px-6 py-4 font-mono font-bold text-on-surface">@p.CodigoRastreo</td>
                    <td class="px-6 py-4 text-on-surface font-semibold">@p.Cliente?.Nombre</td>
                    <td class="px-6 py-4 text-on-surface-variant">@p.FechaPedido.ToString("dd/MM/yyyy HH:mm")</td>
                    <td class="px-6 py-4 text-primary font-bold">@p.MontoTotal.ToString("C")</td>
                    <td class="px-6 py-4">
                        @if (p.Estado == "Entregado")
                        {
                            <span class="px-3 py-1 bg-green-500/10 text-green-700 border border-green-500/20 rounded-full text-xs font-bold inline-flex items-center gap-1">
                                <span class="material-symbols-outlined text-[14px]">check_circle</span> Entregado
                            </span>
                        }
                        else if (p.Estado == "En Ruta" || p.Estado == "EnCamino")
                        {
                            <span class="px-3 py-1 bg-secondary/10 text-secondary border border-secondary/20 rounded-full text-xs font-bold inline-flex items-center gap-1">
                                <span class="material-symbols-outlined text-[14px] animate-pulse">local_shipping</span> En Ruta
                            </span>
                        }
                        else if (p.Estado == "Cancelado")
                        {
                            <span class="px-3 py-1 bg-error/10 text-error border border-error/20 rounded-full text-xs font-bold inline-flex items-center gap-1">
                                <span class="material-symbols-outlined text-[14px]">cancel</span> Cancelado
                            </span>
                        }
                        else
                        {
                            <span class="px-3 py-1 bg-surface-container-high text-on-surface border border-outline-variant/30 rounded-full text-xs font-bold inline-flex items-center gap-1">
                                <span class="material-symbols-outlined text-[14px]">schedule</span> Pendiente
                            </span>
                        }
                    </td>
                    <td class="px-6 py-4 text-on-surface-variant">
                        @if(p.Usuario != null)
                        {
                            <span class="flex items-center gap-2">
                                <div class="w-6 h-6 rounded-full bg-secondary/20 text-secondary flex items-center justify-center text-xs font-bold">
                                    @p.Usuario.Nombre.Substring(0,1).ToUpper()
                                </div>
                                @p.Usuario.Nombre
                            </span>
                        }
                        else
                        {
                            <span class="text-error font-bold text-xs uppercase bg-error/10 px-2 py-1 rounded">Sin Asignar</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
