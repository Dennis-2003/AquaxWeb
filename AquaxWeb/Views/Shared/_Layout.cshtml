<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AQUAX</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "on-primary-fixed-variant": "#284775",
                        "on-tertiary-container": "#889197",
                        "on-secondary-container": "#005f6d",
                        "secondary-container": "#00e0ff",
                        "on-error-container": "#93000a",
                        "on-primary-fixed": "#001b3d",
                        "primary": "#001430",
                        "on-tertiary-fixed": "#141d21",
                        "on-secondary-fixed": "#001f25",
                        "surface-container-low": "#eff4ff",
                        "background": "#f8f9ff",
                        "surface-container-highest": "#d3e4fe",
                        "outline": "#747780",
                        "tertiary-fixed-dim": "#bfc8ce",
                        "tertiary-container": "#212a2e",
                        "surface-container-lowest": "#ffffff",
                        "outline-variant": "#c4c6d0",
                        "tertiary": "#0d151a",
                        "on-surface-variant": "#43474f",
                        "on-error": "#ffffff",
                        "primary-fixed": "#d6e3ff",
                        "surface-dim": "#cbdbf5",
                        "surface-variant": "#d3e4fe",
                        "on-surface": "#0b1c30",
                        "on-background": "#0b1c30",
                        "on-secondary-fixed-variant": "#004e5a",
                        "error-container": "#ffdad6",
                        "surface-tint": "#415f8f",
                        "tertiary-fixed": "#dbe4ea",
                        "surface": "#f8f9ff",
                        "on-primary-container": "#7490c3",
                        "error": "#ba1a1a",
                        "secondary-fixed-dim": "#00daf8",
                        "inverse-primary": "#aac7fd",
                        "primary-container": "#002855",
                        "inverse-surface": "#213145",
                        "inverse-on-surface": "#eaf1ff",
                        "secondary": "#006877",
                        "secondary-fixed": "#a5eeff",
                        "on-secondary": "#ffffff",
                        "on-tertiary": "#ffffff",
                        "surface-container-high": "#dce9ff",
                        "surface-container": "#e5eeff",
                        "primary-fixed-dim": "#aac7fd",
                        "surface-bright": "#f8f9ff",
                        "on-tertiary-fixed-variant": "#3f484d",
                        "on-primary": "#ffffff"
                    },
                    borderRadius: {
                        DEFAULT: "0.25rem",
                        lg: "0.5rem",
                        xl: "0.75rem",
                        full: "9999px"
                    },
                    fontFamily: {
                        "headline-xl": ["Montserrat"],
                        "headline-lg": ["Montserrat"],
                        "body-md": ["Inter"],
                        "body-lg": ["Inter"],
                        "label-sm": ["Inter"],
                        "label-md": ["Inter"],
                        "headline-lg-mobile": ["Montserrat"],
                        "headline-md": ["Montserrat"]
                    },
                    fontSize: {
                        "headline-xl": ["48px", { lineHeight: "56px", letterSpacing: "-0.02em", fontWeight: "700" }],
                        "headline-lg": ["32px", { lineHeight: "40px", letterSpacing: "-0.01em", fontWeight: "600" }],
                        "body-md": ["16px", { lineHeight: "24px", fontWeight: "400" }],
                        "body-lg": ["18px", { lineHeight: "28px", fontWeight: "400" }],
                        "label-sm": ["12px", { lineHeight: "16px", fontWeight: "500" }],
                        "label-md": ["14px", { lineHeight: "20px", letterSpacing: "0.05em", fontWeight: "600" }],
                        "headline-lg-mobile": ["28px", { lineHeight: "36px", fontWeight: "600" }],
                        "headline-md": ["24px", { lineHeight: "32px", fontWeight: "600" }]
                    }
                }
            }
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            vertical-align: middle;
        }
        .glass-card {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.3);
        }
        .product-hover-effect {
            transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease;
        }
        .product-hover-effect:hover {
            transform: translateY(-4px);
            box-shadow: 0px 8px 30px rgba(0, 40, 85, 0.12);
        }
        .submenu.hidden { display: none; }
        .bi-chevron-down { transition: transform 0.2s; }
        .rotate-180 { transform: rotate(180deg); }
    </style>
</head>
<body class="bg-background text-on-background min-h-screen flex flex-col font-body-md overflow-x-hidden">
    <header class="fixed top-0 left-0 w-full bg-surface/80 backdrop-blur-md shadow-[0px_4px_20px_rgba(0,40,85,0.05)] z-50">
        <nav class="flex justify-between items-center px-4 h-16 w-full max-w-[1200px] mx-auto">
            <a class="flex items-center gap-2" asp-controller="Home" asp-action="Index">
                <span class="material-symbols-outlined text-primary" style="font-size:28px">water_drop</span>
                <span class="font-headline-md font-bold tracking-tight text-primary">AQUAX</span>
            </a>
            <div class="hidden md:flex items-center gap-6">
                <a class="text-secondary font-semibold hover:text-secondary transition-colors duration-200 flex items-center gap-1" asp-controller="PedidoCliente" asp-action="Crear">
                    <span class="material-symbols-outlined">shopping_cart</span>Pedir Ahora
                </a>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    @if (User.IsInRole("Cliente"))
                    {
                        <a class="text-on-surface-variant hover:text-secondary transition-colors duration-200 flex items-center gap-1" asp-controller="Cliente" asp-action="Index">
                            <span class="material-symbols-outlined">dashboard</span>Mi Panel
                        </a>
                        <a class="text-on-surface-variant hover:text-secondary transition-colors duration-200 flex items-center gap-1" asp-controller="PedidoCliente" asp-action="MisPedidos">
                            <span class="material-symbols-outlined">inventory_2</span>Mis Pedidos
                        </a>
                    }
                    <form asp-controller="Account" asp-action="Logout" method="post" class="inline">
                        <button type="submit" class="bg-secondary text-on-secondary px-3 py-1.5 rounded-full font-label-md flex items-center gap-1 hover:opacity-90 active:scale-95 transition-all">
                            <span class="material-symbols-outlined" style="font-size:18px">logout</span>
                            @User.Identity.Name
                        </button>
                    </form>
                }
                else
                {
                    <a class="bg-secondary text-on-secondary px-3 py-1.5 rounded-full font-label-md flex items-center gap-1 hover:opacity-90 active:scale-95 transition-all" asp-controller="Account" asp-action="Login">
                        <span class="material-symbols-outlined" style="font-size:18px">login</span>
                        Acceder
                    </a>
                }
            </div>
            <button class="flex md:hidden items-center justify-center w-10 h-10 rounded-full text-on-surface-variant hover:bg-surface-container-high transition-colors" onclick="document.getElementById('mobileMenu').classList.toggle('hidden')">
                <span class="material-symbols-outlined">menu</span>
            </button>
        </nav>
        <div id="mobileMenu" class="hidden md:hidden bg-surface border-t border-outline-variant/20 px-4 py-4">
            <div class="flex flex-col gap-3">
                <a class="flex items-center gap-2 text-on-surface-variant hover:text-secondary py-1" asp-controller="PedidoCliente" asp-action="Crear">
                    <span class="material-symbols-outlined">shopping_cart</span>Pedir Ahora
                </a>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    @if (User.IsInRole("Cliente"))
                    {
                        <a class="flex items-center gap-2 text-on-surface-variant hover:text-secondary py-1" asp-controller="Cliente" asp-action="Index">
                            <span class="material-symbols-outlined">dashboard</span>Mi Panel
                        </a>
                        <a class="flex items-center gap-2 text-on-surface-variant hover:text-secondary py-1" asp-controller="PedidoCliente" asp-action="MisPedidos">
                            <span class="material-symbols-outlined">inventory_2</span>Mis Pedidos
                        </a>
                    }
                    <form asp-controller="Account" asp-action="Logout" method="post">
                        <button type="submit" class="flex items-center gap-2 text-on-surface-variant hover:text-secondary py-1 w-full text-left">
                            <span class="material-symbols-outlined">logout</span>Cerrar sesión (@User.Identity.Name)
                        </button>
                    </form>
                }
                else
                {
                    <a class="flex items-center gap-2 text-on-surface-variant hover:text-secondary py-1" asp-controller="Account" asp-action="Login">
                        <span class="material-symbols-outlined">login</span>Acceder
                    </a>
                }
            </div>
        </div>
    </header>
    <main class="flex-grow pt-16">@RenderBody()</main>

    <div id="snackbar-container" class="fixed bottom-6 left-1/2 -translate-x-1/2 z-[200] flex flex-col gap-2 items-center pointer-events-none"></div>
    @{
        var msg = TempData["Mensaje"] as string;
        var tipo = TempData["TipoMensaje"] as string ?? "success";
    }
    @if (!string.IsNullOrEmpty(msg))
    {
        <div id="snackbar-data" data-message="@msg" data-type="@tipo"></div>
    }

    <footer class="bg-primary text-on-primary w-full rounded-t-xl border-t border-outline-variant/10 flex flex-col items-center py-8 px-4 gap-3 text-center mt-12">
        <div class="font-headline-md text-xl text-secondary-fixed font-bold tracking-tight mb-4">AQUAX</div>
        <div class="flex flex-wrap justify-center gap-4">
            <a class="text-surface-variant/80 hover:text-secondary-fixed transition-colors font-body-md" asp-controller="Home" asp-action="Index">Inicio</a>
            <a class="text-surface-variant/80 hover:text-secondary-fixed transition-colors font-body-md" asp-controller="PedidoCliente" asp-action="Crear">Productos</a>
            <a class="text-surface-variant/80 hover:text-secondary-fixed transition-colors font-body-md" asp-controller="Account" asp-action="Login">Acceder</a>
        </div>
        <div class="text-surface-variant/60 font-body-md">
            &copy; 2024 AQUAX Purified Water. Todos los derechos reservados.
        </div>
    </footer>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
