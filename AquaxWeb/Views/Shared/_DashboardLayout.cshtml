@inject AquaxWeb.Services.IAccessibilidadService AccService
@{
    var accConfig = Context.User.FindFirst("UsuarioId")?.Value is string uid
        ? await AccService.ObtenerConfiguracionAsync(int.Parse(uid))
        : null;
    var modoOscuro = accConfig?.ModoOscuro == true;
    var nivelZoom = accConfig?.NivelZoom ?? 100;
    var filtroColor = accConfig?.FiltroColor ?? "";
}

<!DOCTYPE html>
<html lang="es" data-bs-theme="@(modoOscuro ? "dark" : "light")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AQUAX</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body { zoom: @nivelZoom%; }
        html@{if (!string.IsNullOrEmpty(filtroColor) && filtroColor != "grayscale") {<text>:not(#dummy)</text>}} { filter: @(filtroColor switch {
            "grayscale" => "grayscale(1)",
            _ => "none"
        }); }
        .sidebar-collapse { display: none; }
        .sidebar-collapse.open { display: block; }
    </style>
</head>
<body class="bg-gray-100 text-gray-800 antialiased @(modoOscuro ? "bg-gray-900 text-gray-100" : "")">
    <div class="flex h-screen overflow-hidden">

        <aside class="sidebar bg-gray-900 text-white w-64 flex flex-col shrink-0">
            <div class="p-4 border-b border-gray-700">
                <h4 class="text-lg font-bold flex items-center gap-2">
                    <img src="~/svg/logo.svg" alt="AQUAX" class="h-7 brightness-0 invert" />
                </h4>
                <p class="text-xs text-gray-400 mt-0.5">@User.Identity?.Name</p>
            </div>

            <nav class="flex-1 px-3 py-2 space-y-1 text-sm">
                <a class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-gray-700 transition" asp-controller="Dashboard" asp-action="Index">
                    <span class="material-symbols-outlined text-[20px]">dashboard</span>Inicio
                </a>
                <a class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-gray-700 transition" asp-controller="Pedidos" asp-action="Index">
                    <span class="material-symbols-outlined text-[20px]">history</span>Historial de Pedidos
                </a>
                <a class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-gray-700 transition" asp-controller="Despacho" asp-action="Index">
                    <span class="material-symbols-outlined text-[20px]">local_shipping</span>Logística y Despacho
                </a>
                <a class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-gray-700 transition" asp-controller="Caja" asp-action="Index">
                    <span class="material-symbols-outlined text-[20px]">account_balance_wallet</span>Corte de Caja Diario
                </a>
                
                @if (User.IsInRole("Administrador"))
                {
                    <a class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-gray-700 transition" asp-controller="Admin" asp-action="Index">
                        <span class="material-symbols-outlined text-[20px]">badge</span>Gestión de Empleados
                    </a>
                }

                <div>
                    <button class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-gray-700 transition w-full text-left"
                            onclick="toggleSubmenu(this)">
                        <span class="material-symbols-outlined text-[20px]">settings</span>Ajustes <span class="material-symbols-outlined ml-auto text-[16px] bi-chevron-down">expand_more</span>
                    </button>
                    <div class="submenu hidden ml-4 mt-1 space-y-1">
                        <a class="flex items-center gap-3 px-3 py-1.5 rounded-lg hover:bg-gray-700 transition" asp-controller="Accesibilidad" asp-action="Index">
                            <span class="material-symbols-outlined text-[18px]">visibility</span>Accesibilidad
                        </a>
                        <a class="flex items-center gap-3 px-3 py-1.5 rounded-lg hover:bg-gray-700 transition" asp-controller="Perfil" asp-action="Index">
                            <span class="material-symbols-outlined text-[18px]">person</span>Ajustes del Sistema
                        </a>
                        @if (User.IsInRole("Administrador"))
                        {
                            <a class="flex items-center gap-3 px-3 py-1.5 rounded-lg hover:bg-gray-700 transition" asp-controller="Clientes" asp-action="Index">
                                <span class="material-symbols-outlined text-[18px]">groups</span>Clientes
                            </a>
                            <a class="flex items-center gap-3 px-3 py-1.5 rounded-lg hover:bg-gray-700 transition" asp-controller="Productos" asp-action="Index">
                                <span class="material-symbols-outlined text-[18px]">inventory_2</span>Productos
                            </a>
                        }
                    </div>
                </div>
            </nav>

            <div class="p-3 border-t border-gray-700">
                <form asp-controller="Account" asp-action="Logout" method="post">
                    <button type="submit" class="w-full text-sm flex items-center gap-2 px-3 py-2 rounded-lg border border-gray-600 hover:bg-gray-700 transition">
                        <i class="bi bi-box-arrow-right"></i>Cerrar Sesión
                    </button>
                </form>
            </div>
        </aside>

        <main class="flex-1 overflow-auto p-6">@RenderBody()</main>
    </div>

    <div id="snackbar-container" class="fixed bottom-6 left-1/2 -translate-x-1/2 z-[200] flex flex-col gap-2 items-center pointer-events-none"></div>
    @{
        var msg = TempData["Mensaje"] as string;
        var tipo = TempData["TipoMensaje"] as string ?? "success";
    }
    @if (!string.IsNullOrEmpty(msg))
    {
        <div id="snackbar-data" data-message="@msg" data-type="@tipo"></div>
    }

    <script>
        function toggleSubmenu(btn) {
            const sub = btn.nextElementSibling;
            sub.classList.toggle('hidden');
            const icon = btn.querySelector('.bi-chevron-down');
            if (icon) icon.classList.toggle('rotate-180');
        }
    </script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
