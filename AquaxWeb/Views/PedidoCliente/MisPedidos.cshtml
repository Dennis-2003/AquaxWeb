@model List<Pedido>

@{
    ViewData["Title"] = "Mis Pedidos";
    Layout = "_LayoutDashboard";
}

<div class="mb-lg">
    <div class="flex items-center gap-sm mb-2">
        <span class="material-symbols-outlined text-primary text-3xl">inventory_2</span>
        <h2 class="font-headline-xl text-headline-xl text-primary">Mis Pedidos</h2>
    </div>
    <p class="text-on-surface-variant font-body-lg">Consulta el historial y estado de todos tus pedidos de hidratación premium.</p>
</div>

@if (Model == null || Model.Count == 0)
{
    <div class="bg-surface-container-lowest rounded-xl shadow-[0px_4px_20px_rgba(0,40,85,0.05)] p-12 text-center flex flex-col items-center justify-center min-h-[400px]">
        <span class="material-symbols-outlined text-[80px] text-surface-variant mb-6" style="font-variation-settings: 'FILL' 1;">package_2</span>
        <h3 class="font-headline-lg text-headline-lg text-on-surface mb-2">Aún no tienes pedidos</h3>
        <p class="text-on-surface-variant font-body-md mb-8 max-w-md">Parece que tu historial está vacío. Realiza tu primer pedido de bidones de agua premium y comienza a disfrutar del mejor servicio.</p>
        <a asp-action="Crear" class="bg-primary text-white px-lg py-sm rounded-xl font-headline-md flex items-center gap-2 hover:opacity-90 active:scale-95 transition-all shadow-lg">
            <span class="material-symbols-outlined">add_shopping_cart</span>
            Hacer mi primer pedido
        </a>
    </div>
}
else
{
    <div class="bg-surface-container-lowest rounded-xl shadow-[0px_4px_20px_rgba(0,40,85,0.05)] overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead class="bg-surface-container font-label-sm text-on-surface-variant">
                    <tr>
                        <th class="px-md py-4">Código / ID</th>
                        <th class="px-md py-4">Fecha</th>
                        <th class="px-md py-4">Estado</th>
                        <th class="px-md py-4">Total</th>
                        <th class="px-md py-4">Repartidor</th>
                        <th class="px-md py-4"></th>
                    </tr>
                </thead>
                <tbody class="font-body-md text-on-surface bg-white">
                    @foreach (var pedido in Model)
                    {
                        <tr class="border-b border-outline-variant hover:bg-surface-container-low transition-colors group">
                            <td class="px-md py-4 font-bold text-primary">@pedido.CodigoRastreo</td>
                            <td class="px-md py-4 text-on-surface-variant">@pedido.FechaPedido.ToString("dd MMM, yyyy")</td>
                            <td class="px-md py-4">
                                @if (pedido.Estado == "Entregado")
                                {
                                    <span class="inline-flex items-center gap-1 bg-surface-container-highest text-primary px-sm py-1 rounded-full text-xs font-bold">
                                        <span class="w-2 h-2 rounded-full bg-primary"></span>
                                        Entregado
                                    </span>
                                }
                                else if (pedido.Estado == "En Ruta" || pedido.Estado == "En Tránsito")
                                {
                                    <span class="inline-flex items-center gap-1 bg-secondary-container text-on-secondary-container px-sm py-1 rounded-full text-xs font-bold">
                                        <span class="w-2 h-2 rounded-full bg-on-secondary-container animate-pulse"></span>
                                        @pedido.Estado
                                    </span>
                                }
                                else if (pedido.Estado == "Cancelado")
                                {
                                    <span class="inline-flex items-center gap-1 bg-error-container text-on-error-container px-sm py-1 rounded-full text-xs font-bold">
                                        <span class="w-2 h-2 rounded-full bg-error"></span>
                                        Cancelado
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center gap-1 bg-surface-variant text-on-surface-variant px-sm py-1 rounded-full text-xs font-bold">
                                        <span class="w-2 h-2 rounded-full bg-outline"></span>
                                        @pedido.Estado
                                    </span>
                                }
                            </td>
                            <td class="px-md py-4 font-medium">@pedido.MontoTotal.ToString("C")</td>
                            <td class="px-md py-4 text-on-surface-variant">
                                @(pedido.Usuario != null ? pedido.Usuario.Nombre : "Sin asignar")
                            </td>
                            <td class="px-md py-4 text-right">
                                <a asp-controller="PedidoCliente" asp-action="Rastrear" asp-route-codigoRastreo="@pedido.CodigoRastreo" class="text-secondary font-label-md hover:underline flex items-center justify-end gap-1">
                                    <span class="material-symbols-outlined" style="font-size:18px">visibility</span>
                                    Detalle
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
