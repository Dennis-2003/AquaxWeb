@model Usuario
@{
    ViewData["Title"] = "Ajustes del Sistema";
}

<h2 class="text-2xl font-bold mb-6">Ajustes del Sistema</h2>

<div class="max-w-lg">
    <div class="bg-white rounded-xl shadow-sm p-6">
        <form asp-action="Guardar" method="post">
            <div class="mb-4">
                <label class="block text-sm font-medium mb-1">Correo</label>
                <input class="w-full border border-gray-300 rounded-lg px-3 py-2 bg-gray-100 text-gray-500 text-sm" value="@Model.Correo" disabled readonly />
            </div>
            <div class="mb-4">
                <label class="block text-sm font-medium mb-1" for="nombre">Nombre Completo</label>
                <input type="text" name="nombre" class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 outline-none text-sm" value="@Model.Nombre" required />
            </div>
            <div class="mb-4">
                <label class="block text-sm font-medium mb-1" for="telefono">Teléfono</label>
                <input type="text" name="telefono" class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 outline-none text-sm" value="@Model.Telefono" />
            </div>
            <button type="submit" class="bg-blue-600 text-white px-5 py-2 rounded-lg text-sm hover:bg-blue-700 transition">
                <i class="bi bi-floppy me-1"></i>Guardar
            </button>
        </form>
    </div>
</div>
