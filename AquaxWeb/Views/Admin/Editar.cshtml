@model Usuario
@{
    ViewData["Title"] = "Editar Empleado";
}

<div class="mb-8 flex items-center justify-between">
    <div>
        <h1 class="text-3xl font-headline-md font-bold text-on-surface">Editar Empleado</h1>
        <p class="text-on-surface-variant font-body-md mt-1">Actualiza los datos de @Model.Nombre.</p>
    </div>
</div>

<div class="max-w-xl">
    <div class="bg-surface-container-lowest border border-outline-variant/30 rounded-2xl shadow-[0px_4px_20px_rgba(0,40,85,0.05)] p-8">
        <form method="post">
            <input type="hidden" name="id" value="@Model.Id" />
            <div asp-validation-summary="ModelOnly" class="text-error text-sm font-bold mb-4 bg-error/10 p-3 rounded-lg border border-error/20"></div>
            
            <div class="mb-5">
                <label class="block text-sm font-bold text-on-surface mb-2 uppercase tracking-wider">Nombre Completo</label>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant">badge</span>
                    <input type="text" name="nombre" class="w-full bg-surface-container border border-outline-variant rounded-xl pl-10 pr-4 py-3 text-on-surface focus:ring-2 focus:ring-secondary focus:border-secondary transition-shadow text-sm" value="@Model.Nombre" required />
                </div>
            </div>

            <div class="mb-5">
                <label class="block text-sm font-bold text-on-surface mb-2 uppercase tracking-wider">Correo Electrónico</label>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant">mail</span>
                    <input type="email" name="correo" class="w-full bg-surface-container border border-outline-variant rounded-xl pl-10 pr-4 py-3 text-on-surface focus:ring-2 focus:ring-secondary focus:border-secondary transition-shadow text-sm" value="@Model.Correo" required />
                </div>
            </div>

            <div class="mb-8">
                <label class="block text-sm font-bold text-on-surface mb-2 uppercase tracking-wider">Nivel de Acceso (Rol)</label>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant">admin_panel_settings</span>
                    <select name="rol" class="w-full bg-surface-container border border-outline-variant rounded-xl pl-10 pr-4 py-3 text-on-surface focus:ring-2 focus:ring-secondary focus:border-secondary transition-shadow text-sm cursor-pointer appearance-none">
                        <option value="Trabajador" selected="@(Model.Rol == "Trabajador")">Trabajador (Repartidor / Cajero)</option>
                        <option value="Administrador" selected="@(Model.Rol == "Administrador")">Administrador (Acceso Total)</option>
                    </select>
                </div>
            </div>

            <div class="flex gap-4">
                <button type="submit" class="flex-1 bg-secondary text-on-secondary py-3 rounded-xl font-bold text-sm hover:bg-secondary/90 transition shadow-sm flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined text-[20px]">save</span> Guardar Cambios
                </button>
                <a asp-action="Index" class="bg-surface-container-highest text-on-surface py-3 px-6 rounded-xl font-bold text-sm hover:bg-outline-variant/30 transition flex items-center justify-center">
                    Cancelar
                </a>
            </div>
        </form>
    </div>
</div>
