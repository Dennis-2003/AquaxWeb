                            <stop offset="0%" stop-color="#001430" stop-opacity="0.3" />
                            <stop offset="50%" stop-color="#006877" stop-opacity="0.15" />
                            <stop offset="100%" stop-color="#00e0ff" stop-opacity="0" />
