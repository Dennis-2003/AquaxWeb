                            </defs>
                            <circle cx="140" cy="140" r="120" fill="url(#radar-grad)" />
                            <circle cx="140" cy="140" r="90" fill="none" stroke="#006877" stroke-width="1" stroke-dasharray="6 4" opacity="0.3" />
                            <circle cx="140" cy="140" r="60" fill="none" stroke="#006877" stroke-width="1" stroke-dasharray="6 4" opacity="0.3" />
                            <circle cx="140" cy="140" r="30" fill="none" stroke="#006877" stroke-width="1" stroke-dasharray="6 4" opacity="0.3" />
                            <circle cx="140" cy="140" r="4" fill="#006877" />
                            <line x1="140" y1="140" x2="200" y2="80" stroke="#006877" stroke-width="1.5" opacity="0.4" />
                            <line x1="140" y1="140" x2="80" y2="190" stroke="#006877" stroke-width="1.5" opacity="0.4" />
                            <circle cx="200" cy="80" r="3" fill="#00e0ff" />
                            <circle cx="80" cy="190" r="3" fill="#00e0ff" />
                            <circle cx="170" cy="100" r="2" fill="#006877" opacity="0.5" />
                            <circle cx="110" cy="170" r="2" fill="#006877" opacity="0.5" />
                            <circle cx="160" cy="180" r="2" fill="#006877" opacity="0.5" />
                            <circle cx="100" cy="100" r="2" fill="#006877" opacity="0.5" />
                            <path d="M140 140 L180 120" stroke="#00e0ff" stroke-width="4" stroke-linecap="round" />
                            <path d="M140 140 L120 170" stroke="#000000" stroke-width="4" stroke-linecap="round" opacity="0.08" />
                            <text x="205" y="78" font-size="9" fill="#006877" font-family="Inter,sans-serif" font-weight="600">Centro</text>
                            <text x="60" y="200" font-size="9" fill="#006877" font-family="Inter,sans-serif" font-weight="600">Municipios</text>
                        </svg>
                    </div>
                </div>
            </div>
        </section>

        <!-- CTA Final -->
        <section class="px-margin-mobile py-xl bg-primary relative overflow-hidden">
            <div class="absolute inset-0">
                <svg class="w-full h-full" viewBox="0 0 1440 400" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="200" cy="350" r="250" fill="#ffffff" opacity="0.03" />
                    <circle cx="1200" cy="50" r="200" fill="#ffffff" opacity="0.03" />
                    <path d="M0 200 Q 360 100, 720 180 T 1440 150 L 1440 400 L 0 400 Z" fill="#ffffff" opacity="0.03" />
                </svg>
            </div>
            <div class="max-w-xl mx-auto text-center relative z-10">
                <h2 class="font-headline-lg text-headline-lg text-on-primary mb-md">¿Listo para el cambio?</h2>
                <p class="font-body-lg text-body-lg text-on-primary/80 mb-lg">Únete a miles de clientes que ya disfrutan agua purificada de verdad.</p>
                <div class="flex flex-wrap items-center justify-center gap-sm">
                    <a class="inline-flex items-center justify-center bg-on-primary text-primary font-semibold px-md py-sm rounded-full shadow-sm hover:bg-on-primary/90 transition-all text-sm" asp-controller="PedidoCliente" asp-action="Crear">
                        Pedir Ahora
                    </a>
                    <a class="inline-flex items-center justify-center border border-on-primary text-on-primary font-semibold px-md py-sm rounded-full hover:bg-white/10 transition-all text-sm" asp-controller="Account" asp-action="RegistroCliente">
                        Crear Cuenta
                    </a>
                </div>
            </div>
        </section>
    </main>

    <!-- Footer -->
    <footer class="bg-[#0a1628] text-on-primary py-lg px-margin-mobile flex flex-col items-center gap-base text-center w-full">
        <img src="~/svg/logo.svg" alt="AQUAX" class="h-10 brightness-0 invert" />
        <nav class="flex flex-wrap justify-center gap-md my-md">
            <a class="text-surface-variant/80 font-body-md hover:text-secondary-fixed transition-colors" asp-controller="PedidoCliente" asp-action="Crear">Pedir Ahora</a>
            <a class="text-surface-variant/80 font-body-md hover:text-secondary-fixed transition-colors" asp-controller="Account" asp-action="RegistroCliente">Registrarse</a>
            <a class="text-surface-variant/80 font-body-md hover:text-secondary-fixed transition-colors" asp-controller="Account" asp-action="Login">Iniciar Sesión</a>
        </nav>
        <div class="w-full border-t border-outline-variant/10 my-md"></div>
        <p class="font-body-md text-body-md text-on-primary-container/60">
            © @DateTime.Now.Year AQUAX Agua Purificada. Todos los derechos reservados.
        </p>
    </footer>

    <script>
        window.addEventListener('scroll', () => {
            const header = document.querySelector('header');
            if (window.scrollY > 20) {
                header.classList.add('shadow-md');
            } else {
                header.classList.remove('shadow-md');
            }
        });
    </script>
</body>
</html>
