        </section>

        <!-- ¿Qué es AQUAX? -->
        <section class="px-margin-mobile py-xl bg-surface-container-low">
            <div class="max-w-container-max mx-auto">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-gutter items-center">
                    <div>
                        <span class="inline-block px-sm py-xs bg-secondary-fixed-dim/20 text-on-secondary-fixed-variant rounded-full text-label-sm font-label-sm mb-base uppercase tracking-widest">Quiénes Somos</span>
